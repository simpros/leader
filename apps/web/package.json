{
  "name": "@leader/web",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "db:seed": "bun ./src/seed.ts",
    "build": "vite build",
    "postbuild": "cp -r ../../packages/db/drizzle build/server/drizzle",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "bun test --conditions browser",
    "test:e2e": "bun --bun --env-file=.env.e2e playwright test"
  },
  "devDependencies": {
    "@leader/auth": "workspace:*",
    "@leader/db": "workspace:*",
    "@leader/eslint-config": "workspace:*",
    "@leader/logging": "workspace:*",
    "@leader/tailwind-config": "workspace:*",
    "@leader/ui": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-node": "5.5.2",
    "@sveltejs/kit": "2.50.2",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "^1.3.9",
    "@types/nodemailer": "^7.0.10",
    "better-auth": "1.4.18",
    "bits-ui": "^2.16.2",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "nodemailer": "^8.0.1",
    "runed": "^0.37.1",
    "svelte": "5.53.6",
    "svelte-check": "4.3.6",
    "tailwindcss": "^4.0.0",
    "typescript": "5.9.3",
    "valibot": "^1.2.0",
    "vite": "7.3.1"
  },
  "dependencies": {}
}
