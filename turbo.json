{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_BASE_URL",
        "GOOGLE_PLACES_API_KEY",
        "OPENROUTER_API_KEY",
        "OPENROUTER_MODEL",
        "BRAVE_API_KEY",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_USER",
        "SMTP_PASS",
        "EMAIL_FROM",
        "DYNATRACE_LOG_INGEST_URL",
        "DYNATRACE_API_TOKEN",
        "DYNATRACE_LOGGING",
        "BOOTSTRAP_USER_NAME",
        "BOOTSTRAP_USER_EMAIL",
        "BOOTSTRAP_ORGANIZATION_NAME",
        "BOOTSTRAP_ORGANIZATION_SLUG"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".svelte-kit/**", "build/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {},
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "db:studio": {
      "cache": false
    },
    "auth:generate": {
      "cache": false
    }
  }
}
